{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "target": "ES2021",
    "lib": ["ES2021"],
    "moduleResolution": "Bundler",
    "jsx": "react-native",
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "types": ["react", "react-native", "jest"]
  },
  "exclude": [
    "node_modules",
    "supabase/functions/**/*",
    "**/*.test.ts",
    "**/*.spec.ts",
    "**/*.test.tsx",
    "**/*.spec.tsx"
  ],
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "types/**/*.d.ts"
  ]
}
